{
    "name": "shop-demo",
    "version": "0.4.0",
    "private": true,
    "scripts": {
        "postinstall": "prisma generate",
        "dev": "next dev",
        "build": "next build",
        "start": "next start",
        "lint": "eslint",
        "format:check": "prettier --check '**/*.{js,ts,tsx,json,css,scss,md}'",
        "format:fix": "prettier --write '**/*.{js,ts,tsx,json,css,scss,md}'",
        "db:start": "docker compose up -d",
        "db:stop": "docker compose down",
        "db:migrate": "dotenv -e .env.local -- npx prisma migrate deploy",
        "db:migrate:dev": "dotenv -e .env.local -- npx prisma migrate dev",
        "db:seed": "dotenv -e .env.local -- npx prisma db seed",
        "db:studio": "dotenv -e .env.local -- npx prisma studio",
        "db:reset": "dotenv -e .env.local -- npx prisma migrate reset"
    },
    "prisma": {
        "seed": "tsx prisma/seed.ts"
    },
    "dependencies": {
        "@hookform/resolvers": "^5.4.0",
        "@prisma/client": "^5.22.0",
        "@radix-ui/react-popover": "^1.1.15",
        "@radix-ui/react-radio-group": "^1.4.1",
        "@tanstack/react-query": "^5.100.10",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "lucide-react": "^1.14.0",
        "motion": "^12.40.0",
        "next": "16.2.6",
        "react": "19.2.4",
        "react-dom": "19.2.4",
        "react-hook-form": "^7.79.0",
        "sonner": "^2.0.7",
        "tailwind-merge": "^3.6.0",
        "zod": "^4.4.3",
        "zustand": "^5.0.13"
    },
    "devDependencies": {
        "@tailwindcss/postcss": "^4",
        "@tanstack/react-query-devtools": "^5.100.10",
        "@types/node": "^20",
        "@types/react": "^19",
        "@types/react-dom": "^19",
        "dotenv-cli": "^11.0.0",
        "eslint": "^9",
        "eslint-config-next": "16.2.6",
        "eslint-config-prettier": "^10.1.8",
        "prettier": "^3.8.3",
        "prisma": "^5.22.0",
        "tailwindcss": "^4",
        "tsx": "^4.21.0",
        "typescript": "^5"
    }
}
